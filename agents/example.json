{
  "agentName": "example",
  "workspaceRoot": "/home/agent/workspace",
  "tickIntervals": {
    "active": 1000,
    "idle": 30000,
    "sleep": 300000
  },
  "watchPaths": [
    "/home/agent/workspace/memory",
    "/home/agent/workspace/projects"
  ],
  "monitoring": {
    "git": {
      "enabled": true,
      "interval": 5000
    },
    "email": {
      "enabled": false,
      "interval": 60000
    }
  },
  "healthCheckPort": 41100
}
